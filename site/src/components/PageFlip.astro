---
import type { Recipe } from '../lib/loadRecipes';

interface Props {
  prev?: Recipe;
  next?: Recipe;
}
const { prev, next } = Astro.props;
---
<nav class="page-flip" aria-label="Recipe navigation" data-page-flip
  data-prev={prev?.href ?? ''}
  data-next={next?.href ?? ''}
>
  {prev ? (
    <a href={prev.href} class="flip-btn flip-prev" rel="prev" aria-label={`Previous: ${prev.title}`}>
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <path d="M12 4 6 10l6 6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="flip-meta">
        <span class="flip-eyebrow">Previous</span>
        <span class="flip-title">{prev.title}</span>
      </span>
    </a>
  ) : (
    <span class="flip-btn flip-prev opacity-0 pointer-events-none" aria-hidden="true"></span>
  )}

  {next ? (
    <a href={next.href} class="flip-btn flip-next" rel="next" aria-label={`Next: ${next.title}`}>
      <span class="flip-meta flip-meta--right">
        <span class="flip-eyebrow">Next</span>
        <span class="flip-title">{next.title}</span>
      </span>
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <path d="M8 4l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  ) : (
    <span class="flip-btn flip-next opacity-0 pointer-events-none" aria-hidden="true"></span>
  )}
</nav>

<style>
  .page-flip {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--paper-edge);
  }
  .flip-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 1rem;
    border-radius: 12px;
    color: var(--ink-soft);
    background: var(--paper);
    border: 1px solid var(--paper-edge);
    transition: all 180ms ease;
    max-width: 48%;
  }
  .flip-btn:hover {
    color: var(--terracotta-deep);
    border-color: var(--gold-soft);
    background: var(--paper-deep);
    transform: translateY(-1px);
  }
  .flip-prev:hover svg { transform: translateX(-2px); }
  .flip-next:hover svg { transform: translateX(2px); }
  .flip-btn svg { transition: transform 180ms ease; flex-shrink: 0; }
  .flip-meta { display: flex; flex-direction: column; line-height: 1.2; min-width: 0; }
  .flip-meta--right { text-align: right; }
  .flip-eyebrow {
    font-family: var(--sans);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-faint);
  }
  .flip-title {
    font-family: var(--display);
    font-size: 1.05rem;
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>

<script>
  // Keyboard ←/→ + horizontal swipe to flip pages.
  function init() {
    const el = document.querySelector('[data-page-flip]') as HTMLElement | null;
    if (!el) return;
    const prev = el.dataset.prev;
    const next = el.dataset.next;

    const goPrev = () => { if (prev) window.location.href = prev; };
    const goNext = () => { if (next) window.location.href = next; };

    const onKey = (e: KeyboardEvent) => {
      const tag = (document.activeElement as HTMLElement | null)?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      if (e.key === 'ArrowLeft') { e.preventDefault(); goPrev(); }
      if (e.key === 'ArrowRight') { e.preventDefault(); goNext(); }
    };

    let touchStartX = 0;
    let touchStartY = 0;
    let touching = false;
    const onTouchStart = (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touching = true;
    };
    const onTouchEnd = (e: TouchEvent) => {
      if (!touching) return;
      touching = false;
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) < 60 || Math.abs(dy) > Math.abs(dx)) return;
      if (dx < 0) goNext();
      else goPrev();
    };

    document.addEventListener('keydown', onKey);
    document.addEventListener('touchstart', onTouchStart, { passive: true });
    document.addEventListener('touchend', onTouchEnd);
  }
  // Re-init after Astro view transitions swap content.
  document.addEventListener('astro:page-load', init);
  init();
</script>
