---
import type { Recipe } from '../lib/loadRecipes';
import RecipeActions from './RecipeActions.astro';
import FavoriteHeart from './FavoriteHeart.astro';

interface Props {
  recipe: Recipe;
  showSection?: boolean;
}
const { recipe, showSection = false } = Astro.props;

/** Match the detail page: show method prose, not the duplicated leading ingredient bullets. */
const previewSource = recipe.instructions ?? recipe.body;
const preview = previewSource
  .replace(/[#*`>_\[\]\\]/g, ' ')
  .replace(/\s+/g, ' ')
  .trim()
  .slice(0, 130);
---
<article class="recipe-card group">
  <FavoriteHeart recipe={recipe} variant="card" />
  <RecipeActions recipe={recipe} variant="card" />
  <a href={recipe.href} class="recipe-card__link">
    <div class="flex items-baseline justify-between gap-3">
      <h3 class="recipe-card__title">{recipe.title}</h3>
      {showSection && <span class="recipe-card__section">{recipe.section}</span>}
    </div>
    <div class="mt-1 flex flex-wrap items-center gap-2">
      {recipe.source && <span class="badge badge-source">{recipe.source}</span>}
      {recipe.ingredients && (
        <span class="text-xs text-[color:var(--ink-faint)] font-sans">
          {recipe.ingredients.length} ingredients
        </span>
      )}
    </div>
    {preview && (
      <p class="mt-2 text-sm leading-snug text-[color:var(--ink-soft)] line-clamp-2">{preview}…</p>
    )}
  </a>
</article>

<style is:global>
  /* TOC favorites rebuild cards in JS; they have no Astro scope hash, so layout
     rules must be global for absolute hearts (FavoriteHeart--card) to sit on-card. */
  .recipe-card {
    position: relative;
    display: block;
  }
  /* Reserve room on the left for the absolute-positioned favorite heart so the
     heart never sits on top of the title / badges. The heart occupies roughly
     0.45rem + 26px ≈ 2.1rem from the card edge; 2.5rem leaves a small gap. */
  .recipe-card .recipe-card__link {
    padding-left: 2.5rem;
  }
</style>

<style>
  .recipe-card__link {
    display: block;
    /* Left padding clears the favorite heart (see global rule above). */
    padding: 0.85rem 1rem 0.85rem 2.5rem;
    border-radius: 10px;
    border: 1px solid transparent;
    transition: all 160ms ease;
  }
  .recipe-card:hover .recipe-card__link,
  .recipe-card:focus-within .recipe-card__link {
    background: rgba(195, 157, 78, 0.08);
    border-color: var(--paper-edge);
    transform: translateY(-1px);
  }
  .recipe-card__title {
    font-family: var(--display);
    font-size: 1.18rem;
    color: var(--ink);
    line-height: 1.25;
  }
  .recipe-card:hover .recipe-card__title { color: var(--terracotta-deep); }
  .recipe-card__section {
    font-family: var(--sans);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
