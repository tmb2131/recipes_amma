---
/**
 * WYSIWYG recipe editor (dev always; production when `PUBLIC_RECIPE_EDIT=true`).
 *
 * Mounted once in `BookLayout.astro`. Listens for the `recipe-edit-open`
 * CustomEvent dispatched by `RecipeActions.astro` when the pencil button is
 * clicked, fetches the source `.md` via `GET /api/edit/load`, picks structured
 * vs raw mode based on whether `cleanBody()` confidently splits the file,
 * and saves back via `POST /api/edit/save` (with optional file rename when
 * the title changes).
 *
 * When `PUBLIC_RECIPE_EDIT` is unset/false at build time, this component is
 * omitted so Milkdown is not bundled.
 */
const recipeEditEnabled =
  import.meta.env.DEV || import.meta.env.PUBLIC_RECIPE_EDIT === 'true';
---
{recipeEditEnabled && (
  <dialog data-recipe-edit-modal class="recipe-edit-modal" transition:persist>
    <form method="dialog" class="rem-form" data-rem-form>
      <header class="rem-header">
        <div class="rem-titlebar">
          <strong class="rem-eyebrow" data-rem-eyebrow>Edit recipe</strong>
          <button type="button" class="rem-close" data-rem-close aria-label="Close">×</button>
        </div>
        <div class="rem-fields">
          <label class="rem-field rem-field--full" data-rem-section-field hidden>
            <span class="rem-label">Section</span>
            <select class="rem-input" data-rem-section></select>
          </label>
          <label class="rem-field rem-field--wide">
            <span class="rem-label">Title</span>
            <input type="text" class="rem-input" data-rem-title autocomplete="off" spellcheck="true" />
          </label>
          <label class="rem-field">
            <span class="rem-label">Source <span class="rem-hint">(optional)</span></span>
            <input type="text" class="rem-input" data-rem-source autocomplete="off" placeholder="NYT, Guardian…" />
          </label>
        </div>
        <div class="rem-modes">
          <label class="rem-toggle">
            <input type="checkbox" data-rem-mode-toggle />
            <span>Edit raw markdown</span>
          </label>
          <span class="rem-mode-note" data-rem-mode-note></span>
        </div>
      </header>

      <div class="rem-body">
        <section class="rem-pane" data-rem-pane="structured">
          <div class="rem-pane-section">
            <div class="rem-section-head">
              <h3 class="rem-h3">Ingredients</h3>
              <button type="button" class="rem-btn rem-btn--ghost" data-rem-add-ingredient>+ Add</button>
            </div>
            <ol class="rem-ingredients" data-rem-ingredients></ol>
          </div>
          <div class="rem-pane-section">
            <h3 class="rem-h3">Method</h3>
            <div class="rem-editor" data-rem-method-mount></div>
          </div>
        </section>

        <section class="rem-pane" data-rem-pane="raw" hidden>
          <div class="rem-pane-section">
            <h3 class="rem-h3">Raw markdown</h3>
            <p class="rem-help">Lossless. Saves the whole file verbatim.</p>
            <div class="rem-editor rem-editor--raw" data-rem-raw-mount></div>
          </div>
        </section>
      </div>

      <footer class="rem-footer">
        <span class="rem-status" data-rem-status></span>
        <div class="rem-actions">
          <button type="button" class="rem-btn" data-rem-cancel>Cancel</button>
          <button type="button" class="rem-btn rem-btn--primary" data-rem-save>Save</button>
        </div>
      </footer>
    </form>

    <template data-rem-ingredient-row>
      <li class="rem-ing-row">
        <input type="text" class="rem-input rem-ing-input" />
        <button type="button" class="rem-icon-btn" data-rem-ing-up aria-label="Move up">↑</button>
        <button type="button" class="rem-icon-btn" data-rem-ing-down aria-label="Move down">↓</button>
        <button type="button" class="rem-icon-btn rem-icon-btn--danger" data-rem-ing-remove aria-label="Remove">×</button>
      </li>
    </template>
  </dialog>
)}

{recipeEditEnabled && (
  <script>
    import { cleanBody, cleanTitle } from '../lib/cleanMarkdown';
    import { renderMarkdown } from '../lib/render';
    import { slugify } from '../lib/slug';

    type EditPayload = {
      relativePath: string;
      sectionSlug: string;
      currentBaseName: string;
      recipeHref: string;
      title: string;
      source?: string;
      family: boolean;
    };

    type CreatePayload = {
      defaultSection?: string;
    };

    type FormMode = 'edit' | 'create';

    type Mode = 'structured' | 'raw';

    /**
     * Mirror of `SECTION_ORDER` in `src/lib/loadRecipes.ts`. Hard-coded so the
     * production-built modal doesn't need to ship the loader/cleaner module
     * graph just to render the section dropdown.
     */
    const SECTION_LIST = [
      'Indian',
      'Asian',
      'Fish',
      'Soup',
      'Salad',
      'Dressing',
      'Desserts',
      'Sylvestre',
      'Other',
    ] as const;
    type SectionName = (typeof SECTION_LIST)[number];

    function slugifyClient(input: string): string {
      return input
        .normalize('NFKD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .replace(/['’]/g, '')
        .replace(/&/g, ' and ')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '')
        .replace(/-{2,}/g, '-');
    }

    function findSectionBySlug(slug: string | undefined): SectionName | null {
      if (!slug) return null;
      const want = slug.toLowerCase();
      for (const s of SECTION_LIST) {
        if (slugifyClient(s) === want) return s;
      }
      return null;
    }

    type EditorHandle = {
      destroy: () => Promise<void>;
      getMarkdown: () => string;
    };

    type PendingRecipeSave = {
      relativePath: string;
      oldRelativePath: string;
      href: string;
      oldHref: string;
      title: string;
      source?: string;
      content: string;
      baseName: string;
      savedAt: number;
    };

    if (!(window as any).__recipeEditModalInit) {
      (window as any).__recipeEditModalInit = true;

      const EDIT_API = '/api/edit';
      const PENDING_SAVE_KEY = 'ammas-kitchen:pending-recipe-saves:v1';
      const PENDING_SAVE_TTL_MS = 2 * 60 * 60 * 1000;

      // Lazy-load modal CSS.
      void import('./recipeEditModal.css');

      const $ = <T extends Element = HTMLElement>(sel: string, root: ParentNode = document) =>
        root.querySelector(sel) as T | null;

      let payload: EditPayload | null = null;
      let originalRaw = '';
      let mode: Mode = 'structured';
      let formMode: FormMode = 'edit';
      let editor: EditorHandle | null = null;
      let dirty = false;
      let saving = false;

      function getDialog(): HTMLDialogElement | null {
        return $('[data-recipe-edit-modal]') as HTMLDialogElement | null;
      }

      function setStatus(msg: string, kind: 'info' | 'error' = 'info') {
        const el = $('[data-rem-status]');
        if (!el) return;
        el.textContent = msg;
        el.dataset.kind = kind;
      }

      function setDirty(v: boolean) {
        dirty = v;
      }

      async function loadMilkdown() {
        const [coreMod, cmkMod, gfmMod, utilsMod] = await Promise.all([
          import('@milkdown/kit/core'),
          import('@milkdown/kit/preset/commonmark'),
          import('@milkdown/kit/preset/gfm'),
          import('@milkdown/kit/utils'),
        ]);
        return {
          Editor: coreMod.Editor,
          rootCtx: coreMod.rootCtx,
          defaultValueCtx: coreMod.defaultValueCtx,
          editorViewOptionsCtx: coreMod.editorViewOptionsCtx,
          listenerPlugin: null as any,
          commonmark: cmkMod.commonmark,
          gfm: gfmMod.gfm,
          getMarkdown: utilsMod.getMarkdown,
        };
      }

      async function mountEditor(container: HTMLElement, initial: string): Promise<EditorHandle> {
        const m = await loadMilkdown();
        container.replaceChildren();
        const editorInstance = await m.Editor.make()
          .config((ctx: any) => {
            ctx.set(m.rootCtx, container);
            ctx.set(m.defaultValueCtx, initial);
            ctx.set(m.editorViewOptionsCtx, {
              attributes: { class: 'milkdown-surface', spellcheck: 'true' },
            });
          })
          .use(m.commonmark)
          .use(m.gfm)
          .create();

        // Track dirty: ProseMirror dispatches input events on the contenteditable.
        container.addEventListener('input', () => setDirty(true));
        container.addEventListener('keydown', () => setDirty(true));

        return {
          destroy: async () => {
            try {
              await editorInstance.destroy(true);
            } catch {
              /* ignore */
            }
          },
          getMarkdown: () => editorInstance.action(m.getMarkdown()),
        };
      }

      function renderIngredients(items: string[]) {
        const list = $('[data-rem-ingredients]') as HTMLOListElement | null;
        const tpl = $('[data-rem-ingredient-row]') as HTMLTemplateElement | null;
        if (!list || !tpl) return;
        list.replaceChildren();
        for (const item of items) addIngredientRow(item);
      }

      function addIngredientRow(value = '') {
        const list = $('[data-rem-ingredients]') as HTMLOListElement | null;
        const tpl = $('[data-rem-ingredient-row]') as HTMLTemplateElement | null;
        if (!list || !tpl) return;
        const frag = tpl.content.cloneNode(true) as DocumentFragment;
        const row = frag.querySelector('.rem-ing-row') as HTMLLIElement;
        const input = row.querySelector('.rem-ing-input') as HTMLInputElement;
        input.value = value;
        list.appendChild(frag);
      }

      function readIngredients(): string[] {
        const inputs = document.querySelectorAll<HTMLInputElement>('.rem-ing-input');
        return Array.from(inputs)
          .map((i) => i.value.trim())
          .filter((v) => v.length > 0);
      }

      function moveRow(row: HTMLElement, dir: -1 | 1) {
        const sibling = dir === -1 ? row.previousElementSibling : row.nextElementSibling;
        if (!sibling) return;
        if (dir === -1) row.parentElement?.insertBefore(row, sibling);
        else row.parentElement?.insertBefore(sibling, row);
      }

      function setMode(next: Mode) {
        const structured = $('[data-rem-pane="structured"]');
        const raw = $('[data-rem-pane="raw"]');
        if (!structured || !raw) return;
        structured.toggleAttribute('hidden', next !== 'structured');
        raw.toggleAttribute('hidden', next !== 'raw');
        mode = next;
        const toggle = $('[data-rem-mode-toggle]') as HTMLInputElement | null;
        if (toggle) toggle.checked = next === 'raw';
      }

      function note(msg: string) {
        const el = $('[data-rem-mode-note]');
        if (el) el.textContent = msg;
      }

      function reassembleStructured(args: {
        title: string;
        source?: string;
        ingredients: string[];
        methodMd: string;
      }): string {
        const { title, source, ingredients, methodMd } = args;
        const heading = `# ${title}${source ? ` (${source})` : ''}`;
        const ingredientsBlock = ingredients.length
          ? ingredients.map((i) => `- ${i}`).join('\n')
          : '';
        const parts = [heading.trim()];
        if (ingredientsBlock) parts.push(ingredientsBlock);
        if (methodMd.trim()) parts.push(methodMd.trim());
        return parts.join('\n\n') + '\n';
      }

      function sanitizeForFilename(s: string): string {
        return s
          .replace(/[\\/]/g, '-')
          .replace(/[\u0000-\u001f\u007f]/g, '')
          .replace(/[<>:"|?*]/g, '')
          .replace(/\s+/g, ' ')
          .trim();
      }

      function computeNewBaseName(title: string, source: string | undefined): string {
        const base = sanitizeForFilename(title);
        if (!base) return '';
        const tag = source ? ` (${sanitizeForFilename(source)})` : '';
        return `${base}${tag}.md`;
      }

      function normalizeHref(href: string): string {
        if (!href) return '/';
        const url = new URL(href, location.origin);
        return url.pathname.endsWith('/') ? url.pathname : `${url.pathname}/`;
      }

      function readPendingSaves(): Record<string, PendingRecipeSave> {
        let parsed: Record<string, PendingRecipeSave> = {};
        try {
          parsed = JSON.parse(localStorage.getItem(PENDING_SAVE_KEY) || '{}') as typeof parsed;
        } catch {
          parsed = {};
        }
        const now = Date.now();
        let changed = false;
        for (const [key, value] of Object.entries(parsed)) {
          if (!value || now - value.savedAt > PENDING_SAVE_TTL_MS) {
            delete parsed[key];
            changed = true;
          }
        }
        if (changed) {
          try {
            localStorage.setItem(PENDING_SAVE_KEY, JSON.stringify(parsed));
          } catch {
            /* ignore unavailable localStorage */
          }
        }
        return parsed;
      }

      function storePendingSave(save: PendingRecipeSave) {
        const pending = readPendingSaves();
        pending[save.oldRelativePath] = save;
        pending[save.relativePath] = save;
        try {
          localStorage.setItem(PENDING_SAVE_KEY, JSON.stringify(pending));
        } catch {
          /* ignore unavailable localStorage */
        }
      }

      function updateSourceBadge(article: HTMLElement, source: string | undefined) {
        const tags = $('[data-recipe-tags]', article);
        if (!tags) return;
        let badge = $('[data-recipe-source]', tags) as HTMLElement | null;
        if (!source) {
          badge?.remove();
          return;
        }
        if (!badge) {
          badge = document.createElement('span');
          badge.className = 'badge badge-source';
          badge.dataset.recipeSource = '';
          const actions = tags.querySelector('.recipe-actions');
          tags.insertBefore(badge, actions);
        }
        badge.textContent = source;
      }

      function updateRecipeActions(article: HTMLElement, save: PendingRecipeSave) {
        const btn = $('[data-edit-payload]', article) as HTMLElement | null;
        if (!btn) return;
        try {
          const next = JSON.parse(btn.getAttribute('data-edit-payload') || '{}') as EditPayload;
          next.relativePath = save.relativePath;
          next.currentBaseName = save.baseName;
          next.title = save.title;
          next.source = save.source;
          next.recipeHref = normalizeHref(location.pathname);
          btn.setAttribute('data-edit-payload', JSON.stringify(next));
          btn.setAttribute('aria-label', `Edit ${save.title}`);
        } catch {
          /* ignore malformed existing payload */
        }
      }

      function applyRecipeToCurrentPage(save: PendingRecipeSave): boolean {
        const article = $('[data-recipe-detail]') as HTMLElement | null;
        if (!article) return false;

        const cleaned = cleanBody(save.content, save.title);
        const ingredients = cleaned.ingredients ?? [];
        const methodMd = cleaned.instructions ?? cleaned.body;

        const titleEl = $('[data-recipe-title]', article);
        const crumbEl = $('[data-recipe-breadcrumb-title]', article);
        if (titleEl) titleEl.textContent = save.title;
        if (crumbEl) crumbEl.textContent = save.title;
        document.title = `${save.title} — Amma's Kitchen`;
        updateSourceBadge(article, save.source);

        const body = $('[data-recipe-body]', article);
        const instructionsCol = $('[data-recipe-instructions-col]', article) as HTMLElement | null;
        const prose = $('[data-recipe-instructions]', article);
        if (!body || !instructionsCol || !prose) return false;

        let ingredientsCol = $('[data-recipe-ingredients-col]', article) as HTMLElement | null;
        let ingredientsList = $('[data-recipe-ingredients-list]', article) as HTMLUListElement | null;
        let methodHeading = instructionsCol.querySelector('.instructions-heading');

        if (ingredients.length > 0) {
          if (!ingredientsCol) {
            ingredientsCol = document.createElement('aside');
            ingredientsCol.className = 'ingredients-col';
            ingredientsCol.dataset.recipeIngredientsCol = '';
            ingredientsCol.setAttribute('aria-labelledby', 'ingredients-heading');
            ingredientsCol.innerHTML =
              '<h2 id="ingredients-heading" class="ingredients-heading">Ingredients</h2><ul class="ingredients-list" data-recipe-ingredients-list></ul>';
            body.insertBefore(ingredientsCol, instructionsCol);
          }
          ingredientsList = $('[data-recipe-ingredients-list]', ingredientsCol) as HTMLUListElement | null;
          if (ingredientsList) {
            ingredientsList.replaceChildren(
              ...ingredients.map((item) => {
                const li = document.createElement('li');
                li.textContent = item;
                return li;
              }),
            );
          }
          if (!methodHeading) {
            methodHeading = document.createElement('h2');
            methodHeading.className = 'instructions-heading';
            methodHeading.textContent = 'Method';
            instructionsCol.insertBefore(methodHeading, prose);
          }
          instructionsCol.classList.remove('instructions-col--full');
        } else {
          ingredientsCol?.remove();
          methodHeading?.remove();
          instructionsCol.classList.add('instructions-col--full');
        }

        prose.innerHTML = renderMarkdown(methodMd);
        article.dataset.recipeSourceFile = save.relativePath;
        article.dataset.recipeHref = save.href;
        updateRecipeActions(article, save);
        return true;
      }

      function applyPendingSaveForCurrentPage() {
        const article = $('[data-recipe-detail]') as HTMLElement | null;
        if (!article) return;
        const sourceFile = article.dataset.recipeSourceFile ?? '';
        const href = normalizeHref(article.dataset.recipeHref ?? location.pathname);
        const currentHref = normalizeHref(location.pathname);
        const unique = new Map<string, PendingRecipeSave>();
        for (const save of Object.values(readPendingSaves())) {
          unique.set(`${save.oldRelativePath}\n${save.relativePath}\n${save.savedAt}`, save);
        }
        const match = Array.from(unique.values()).find(
          (save) =>
            save.relativePath === sourceFile ||
            save.oldRelativePath === sourceFile ||
            normalizeHref(save.href) === href ||
            normalizeHref(save.oldHref) === href ||
            normalizeHref(save.href) === currentHref ||
            normalizeHref(save.oldHref) === currentHref,
        );
        if (match) applyRecipeToCurrentPage(match);
      }

      function ensureSectionOptions() {
        const select = $('[data-rem-section]') as HTMLSelectElement | null;
        if (!select) return;
        if (select.options.length === SECTION_LIST.length) return;
        select.replaceChildren();
        for (const s of SECTION_LIST) {
          const opt = document.createElement('option');
          opt.value = s;
          opt.textContent = s;
          select.appendChild(opt);
        }
      }

      function setFormMode(next: FormMode, opts: { defaultSection?: SectionName } = {}) {
        formMode = next;
        const sectionField = $('[data-rem-section-field]') as HTMLElement | null;
        const eyebrow = $('[data-rem-eyebrow]') as HTMLElement | null;
        if (sectionField) sectionField.hidden = false;
        if (eyebrow) eyebrow.textContent = next === 'create' ? 'New recipe' : 'Edit recipe';
        ensureSectionOptions();
        const select = $('[data-rem-section]') as HTMLSelectElement | null;
        if (select) {
          const want = opts.defaultSection ?? 'Other';
          const has = SECTION_LIST.includes(want as SectionName);
          select.value = has ? want : 'Other';
        }
      }

      async function openCreate(p: CreatePayload | undefined) {
        const dlg = getDialog();
        if (!dlg) return;
        payload = null;
        originalRaw = '';
        setDirty(false);
        setStatus('');

        const defaultSection = findSectionBySlug(p?.defaultSection) ?? undefined;
        setFormMode('create', { defaultSection: defaultSection ?? undefined });

        const titleInput = $('[data-rem-title]') as HTMLInputElement | null;
        const sourceInput = $('[data-rem-source]') as HTMLInputElement | null;
        if (titleInput) titleInput.value = '';
        if (sourceInput) sourceInput.value = '';

        if (editor) {
          await editor.destroy();
          editor = null;
        }

        setMode('structured');
        renderIngredients([]);
        const methodMount = $('[data-rem-method-mount]') as HTMLElement | null;
        if (methodMount) editor = await mountEditor(methodMount, '');
        note('New recipe. Add ingredients and method, then Save.');

        dlg.showModal();
        queueMicrotask(() => {
          setDirty(false);
          titleInput?.focus();
        });
      }

      async function openModal(p: EditPayload) {
        const dlg = getDialog();
        if (!dlg) return;
        payload = p;
        const currentSection = findSectionBySlug(p.sectionSlug) ?? undefined;
        setFormMode('edit', { defaultSection: currentSection });
        setDirty(false);
        setStatus('Loading…');

        try {
          const res = await fetch(
            `${EDIT_API}/load?relativePath=${encodeURIComponent(p.relativePath)}`,
          );
          if (!res.ok) throw new Error(`load failed: ${res.status} ${await res.text()}`);
          originalRaw = await res.text();
        } catch (err) {
          setStatus(`Load failed: ${(err as Error).message}`, 'error');
          dlg.showModal();
          return;
        }

        const titleInput = $('[data-rem-title]') as HTMLInputElement | null;
        const sourceInput = $('[data-rem-source]') as HTMLInputElement | null;
        if (titleInput) titleInput.value = p.title;
        if (sourceInput) sourceInput.value = p.source ?? '';

        const cleaned = cleanBody(originalRaw, p.title);
        const hasStructured =
          !!cleaned.ingredients && cleaned.ingredients.length > 0 && !!cleaned.instructions;

        if (editor) {
          await editor.destroy();
          editor = null;
        }

        if (hasStructured) {
          setMode('structured');
          renderIngredients(cleaned.ingredients!);
          const methodMount = $('[data-rem-method-mount]') as HTMLElement | null;
          if (methodMount) editor = await mountEditor(methodMount, cleaned.instructions!);
          note('Structured fields detected. Toggle to edit raw markdown.');
        } else {
          setMode('raw');
          renderIngredients([]);
          const rawMount = $('[data-rem-raw-mount]') as HTMLElement | null;
          if (rawMount) editor = await mountEditor(rawMount, originalRaw);
          note('No clean ingredient block detected — editing raw markdown.');
        }

        setStatus('');
        dlg.showModal();
        // Mark not-dirty after initial mount even though `input` events may have fired.
        queueMicrotask(() => setDirty(false));
      }

      async function switchMode(target: Mode) {
        if (target === mode) return;
        if (dirty) {
          const ok = window.confirm(
            'You have unsaved changes. Switching modes will rebuild the editor from your current values. Continue?',
          );
          if (!ok) {
            const toggle = $('[data-rem-mode-toggle]') as HTMLInputElement | null;
            if (toggle) toggle.checked = mode === 'raw';
            return;
          }
        }

        const titleInput = $('[data-rem-title]') as HTMLInputElement | null;
        const sourceInput = $('[data-rem-source]') as HTMLInputElement | null;
        const title = titleInput?.value.trim() ?? payload?.title ?? '';
        const source = sourceInput?.value.trim() || undefined;

        if (target === 'raw') {
          // structured -> raw: rebuild raw md from current structured values.
          const ingredients = readIngredients();
          const methodMd = editor ? editor.getMarkdown() : '';
          const reassembled = reassembleStructured({ title, source, ingredients, methodMd });
          if (editor) {
            await editor.destroy();
            editor = null;
          }
          setMode('raw');
          const rawMount = $('[data-rem-raw-mount]') as HTMLElement | null;
          if (rawMount) editor = await mountEditor(rawMount, reassembled);
          note('Editing raw markdown. Saves verbatim.');
        } else {
          // raw -> structured: try to split current raw md.
          const currentRaw = editor ? editor.getMarkdown() : originalRaw;
          const cleaned = cleanBody(currentRaw, title);
          if (!cleaned.ingredients || !cleaned.ingredients.length || !cleaned.instructions) {
            const ok = window.confirm(
              "The current markdown doesn't split cleanly into ingredients and method. " +
                'Switch anyway? (Ingredients will be empty; the body becomes the method.)',
            );
            if (!ok) {
              const toggle = $('[data-rem-mode-toggle]') as HTMLInputElement | null;
              if (toggle) toggle.checked = true;
              return;
            }
          }
          if (editor) {
            await editor.destroy();
            editor = null;
          }
          setMode('structured');
          renderIngredients(cleaned.ingredients ?? []);
          const methodMount = $('[data-rem-method-mount]') as HTMLElement | null;
          const methodMd = cleaned.instructions ?? cleaned.body ?? currentRaw;
          if (methodMount) editor = await mountEditor(methodMount, methodMd);
          note('Switched to structured fields.');
        }
        setDirty(true);
      }

      function readEditorContent(title: string, source: string | undefined): string {
        if (mode === 'structured') {
          const methodMd = editor ? editor.getMarkdown() : '';
          return reassembleStructured({
            title,
            source,
            ingredients: readIngredients(),
            methodMd,
          });
        }
        let content = editor ? editor.getMarkdown() : originalRaw;
        if (!content.endsWith('\n')) content += '\n';
        return content;
      }

      async function save() {
        if (saving) return;
        if (formMode === 'create') {
          await saveCreate();
        } else {
          await saveEdit();
        }
      }

      async function saveEdit() {
        if (!payload) return;
        const titleInput = $('[data-rem-title]') as HTMLInputElement | null;
        const sourceInput = $('[data-rem-source]') as HTMLInputElement | null;
        const sectionSelect = $('[data-rem-section]') as HTMLSelectElement | null;
        const title = titleInput?.value.trim() ?? '';
        const source = sourceInput?.value.trim() || undefined;
        if (!title) {
          setStatus('Title cannot be empty.', 'error');
          return;
        }

        const selectedSection = sectionSelect?.value as SectionName | undefined;
        if (!selectedSection || !(SECTION_LIST as readonly string[]).includes(selectedSection)) {
          setStatus('Pick a section.', 'error');
          return;
        }
        const sectionChanged = slugifyClient(selectedSection) !== payload.sectionSlug;

        const content = readEditorContent(title, source);

        // Compute newBaseName if title or source changed.
        const currentInfo = cleanTitle(payload.currentBaseName.replace(/\.md$/i, ''));
        const titleChanged = currentInfo.title !== title;
        const sourceChanged = (currentInfo.source ?? undefined) !== source;
        let newBaseName: string | undefined;
        if (titleChanged || sourceChanged) {
          newBaseName = computeNewBaseName(title, source);
          if (!newBaseName) {
            setStatus('Title produced an empty filename.', 'error');
            return;
          }
        }

        saving = true;
        setStatus('Saving…');
        const saveBtn = $('[data-rem-save]') as HTMLButtonElement | null;
        if (saveBtn) saveBtn.disabled = true;

        try {
          const res = await fetch(`${EDIT_API}/save`, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              relativePath: payload.relativePath,
              content,
              newBaseName,
              ...(sectionChanged ? { newSection: selectedSection } : {}),
            }),
          });
          if (!res.ok) {
            const text = await res.text();
            setStatus(`Save failed: ${res.status} ${text}`, 'error');
            return;
          }
          const result = (await res.json()) as {
            ok: boolean;
            renamed: boolean;
            relativePath: string;
            baseName: string;
            section?: string;
            sectionSlug?: string;
          };
          const newSlug = slugify(cleanTitle(result.baseName.replace(/\.md$/i, '')).title);
          const targetSectionSlug = result.sectionSlug ?? slugifyClient(selectedSection);
          const newHref = result.renamed
            ? `/${targetSectionSlug}/${newSlug}/`
            : payload.recipeHref;
          const pendingSave: PendingRecipeSave = {
            relativePath: result.relativePath,
            oldRelativePath: payload.relativePath,
            href: newHref,
            oldHref: payload.recipeHref,
            title,
            source,
            content,
            baseName: result.baseName,
            savedAt: Date.now(),
          };

          storePendingSave(pendingSave);
          setDirty(false);
          getDialog()?.close();

          if (sectionChanged) {
            // The recipe lives at a new URL now. The old page may still render
            // briefly from build output, but it's stale — navigate to the new
            // section route.
            location.href = newHref;
          } else if (normalizeHref(location.pathname) === normalizeHref(payload.recipeHref)) {
            applyRecipeToCurrentPage(pendingSave);
          } else {
            location.reload();
          }
        } catch (err) {
          setStatus(`Save failed: ${(err as Error).message}`, 'error');
        } finally {
          saving = false;
          if (saveBtn) saveBtn.disabled = false;
        }
      }

      async function saveCreate() {
        const sectionSelect = $('[data-rem-section]') as HTMLSelectElement | null;
        const titleInput = $('[data-rem-title]') as HTMLInputElement | null;
        const sourceInput = $('[data-rem-source]') as HTMLInputElement | null;
        const title = titleInput?.value.trim() ?? '';
        const source = sourceInput?.value.trim() || undefined;
        const section = sectionSelect?.value as SectionName | undefined;

        if (!section || !(SECTION_LIST as readonly string[]).includes(section)) {
          setStatus('Pick a section.', 'error');
          return;
        }
        if (!title) {
          setStatus('Title cannot be empty.', 'error');
          return;
        }
        const baseName = computeNewBaseName(title, source);
        if (!baseName) {
          setStatus('Title produced an empty filename.', 'error');
          return;
        }

        const content = readEditorContent(title, source);

        saving = true;
        setStatus('Saving…');
        const saveBtn = $('[data-rem-save]') as HTMLButtonElement | null;
        if (saveBtn) saveBtn.disabled = true;

        try {
          const res = await fetch(`${EDIT_API}/create`, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ section, baseName, content }),
          });
          if (!res.ok) {
            const text = await res.text();
            // Friendlier message for the most common error case.
            const msg = res.status === 409
              ? `A recipe with that filename already exists in ${section}.`
              : `Create failed: ${res.status} ${text}`;
            setStatus(msg, 'error');
            return;
          }
          const result = (await res.json()) as {
            ok: boolean;
            requiresDeploy: boolean;
            relativePath: string;
            baseName: string;
            section: string;
            sectionSlug: string;
            slug: string;
            href: string;
          };

          // Cache the new recipe so the destination page can render it
          // optimistically — works locally where the page exists immediately.
          const pendingSave: PendingRecipeSave = {
            relativePath: result.relativePath,
            oldRelativePath: result.relativePath,
            href: result.href,
            oldHref: result.href,
            title,
            source,
            content,
            baseName: result.baseName,
            savedAt: Date.now(),
          };
          storePendingSave(pendingSave);
          setDirty(false);
          getDialog()?.close();

          if (result.requiresDeploy) {
            // On Vercel cloud the new file is in the GitHub repo but not yet
            // in the deployed build — landing on the new href would 404.
            // Send the user to the table of contents with a flash message.
            try {
              sessionStorage.setItem(
                'ammas-kitchen:new-recipe-flash',
                JSON.stringify({ title, href: result.href, at: Date.now() }),
              );
            } catch {
              /* ignore unavailable storage */
            }
            location.href = '/contents/';
          } else {
            location.href = result.href;
          }
        } catch (err) {
          setStatus(`Create failed: ${(err as Error).message}`, 'error');
        } finally {
          saving = false;
          if (saveBtn) saveBtn.disabled = false;
        }
      }

      function tryClose() {
        if (saving) return;
        if (dirty) {
          const ok = window.confirm('Discard unsaved changes?');
          if (!ok) return;
        }
        getDialog()?.close();
      }

      function bind() {
        const dlg = getDialog();
        if (!dlg) return;
        if ((dlg as any).__remBound) return;
        (dlg as any).__remBound = true;

        // The native ESC keypress fires the dialog's `cancel` event; intercept
        // so we can prompt on unsaved changes.
        dlg.addEventListener('cancel', (e) => {
          if (saving || dirty) {
            e.preventDefault();
            tryClose();
          }
        });
        // Backdrop click closes.
        dlg.addEventListener('click', (e) => {
          if (e.target === dlg) tryClose();
        });

        $('[data-rem-close]')?.addEventListener('click', tryClose);
        $('[data-rem-cancel]')?.addEventListener('click', tryClose);
        $('[data-rem-save]')?.addEventListener('click', () => void save());
        $('[data-rem-add-ingredient]')?.addEventListener('click', () => {
          addIngredientRow('');
          setDirty(true);
        });
        $('[data-rem-mode-toggle]')?.addEventListener('change', (e) => {
          const checked = (e.target as HTMLInputElement).checked;
          void switchMode(checked ? 'raw' : 'structured');
        });
        // Ingredient row delegation: up/down/remove.
        $('[data-rem-ingredients]')?.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          const row = target.closest('.rem-ing-row') as HTMLElement | null;
          if (!row) return;
          if (target.matches('[data-rem-ing-up]')) {
            moveRow(row, -1);
            setDirty(true);
          } else if (target.matches('[data-rem-ing-down]')) {
            moveRow(row, 1);
            setDirty(true);
          } else if (target.matches('[data-rem-ing-remove]')) {
            row.remove();
            setDirty(true);
          }
        });
        $('[data-rem-ingredients]')?.addEventListener('input', () => setDirty(true));
        $('[data-rem-title]')?.addEventListener('input', () => setDirty(true));
        $('[data-rem-source]')?.addEventListener('input', () => setDirty(true));
        $('[data-rem-section]')?.addEventListener('change', () => setDirty(true));
      }

      function init() {
        bind();
        applyPendingSaveForCurrentPage();
        showNewRecipeFlashIfPresent();
      }

      function showNewRecipeFlashIfPresent() {
        let raw: string | null = null;
        try {
          raw = sessionStorage.getItem('ammas-kitchen:new-recipe-flash');
        } catch {
          return;
        }
        if (!raw) return;
        try {
          sessionStorage.removeItem('ammas-kitchen:new-recipe-flash');
        } catch {
          /* ignore */
        }
        let flash: { title?: string; href?: string; at?: number } = {};
        try {
          flash = JSON.parse(raw) as typeof flash;
        } catch {
          return;
        }
        if (!flash.title) return;
        // Only show the flash on the contents page; navigating anywhere else
        // means it's stale.
        if (!location.pathname.startsWith('/contents')) return;
        const banner = document.createElement('div');
        banner.setAttribute('role', 'status');
        banner.textContent = `Saved "${flash.title}" — it will appear on the site once the next deploy finishes.`;
        banner.style.cssText = [
          'position: fixed',
          'left: 50%',
          'bottom: 1.25rem',
          'transform: translateX(-50%)',
          'z-index: 50',
          'background: rgba(232, 176, 74, 0.95)',
          'color: #2b2118',
          'padding: 0.7rem 1.1rem',
          'border-radius: 10px',
          'border: 1px solid rgba(160, 130, 90, 0.45)',
          'box-shadow: 0 12px 24px rgba(20, 15, 10, 0.18)',
          'font-family: var(--serif, Georgia, serif)',
          'font-size: 0.92rem',
          'max-width: min(36rem, calc(100vw - 2rem))',
          'text-align: center',
        ].join(';');
        document.body.appendChild(banner);
        setTimeout(() => banner.remove(), 7000);
      }

      window.addEventListener('recipe-edit-open', (e: Event) => {
        const detail = (e as CustomEvent<EditPayload>).detail;
        if (!detail) return;
        bind();
        void openModal(detail);
      });

      window.addEventListener('recipe-new-open', (e: Event) => {
        const detail = (e as CustomEvent<CreatePayload | undefined>).detail;
        bind();
        void openCreate(detail);
      });

      // Astro's ClientRouter swaps the body but the dialog has
      // `transition:persist`, so it survives. Re-bind defensively after
      // navigation in case the listener was lost.
      document.addEventListener('astro:page-load', init);
      init();
    }
  </script>
)}
