---
interface Props {
  compact?: boolean;
  autofocus?: boolean;
}
const { compact = false, autofocus = false } = Astro.props;
---
<form
  class:list={[
    'search-box relative flex items-center',
    compact ? 'h-9' : 'h-11',
  ]}
  action="/search/"
  method="get"
  role="search"
  data-search-box
>
  <svg class="pointer-events-none absolute left-3 h-4 w-4 text-[color:var(--ink-faint)]" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <circle cx="9" cy="9" r="6"/>
    <path d="m17 17-3.5-3.5" stroke-linecap="round"/>
  </svg>
  <input
    type="search"
    name="q"
    placeholder="Search recipes…"
    autocomplete="off"
    autofocus={autofocus}
    class:list={[
      'w-full rounded-full border border-[color:var(--paper-edge)] bg-[color:var(--paper)] pl-9 pr-12 font-sans text-sm text-[color:var(--ink)] placeholder:text-[color:var(--ink-faint)] outline-none transition focus:border-[color:var(--gold)] focus:shadow-[0_0_0_3px_rgba(195,157,78,0.15)]',
      compact ? 'h-9' : 'h-11',
    ]}
  />
  <kbd class="pointer-events-none absolute right-3 hidden font-sans text-[10px] uppercase tracking-wider text-[color:var(--ink-faint)] sm:inline-block">/</kbd>
</form>
