---
import '../styles/tailwind.css';
import '../styles/tokens.css';
import '../styles/paper.css';
import { ClientRouter } from 'astro:transitions';
import Drawer from '../components/Drawer.astro';
import SearchBox from '../components/SearchBox.astro';
import RecipeEditModal from '../components/RecipeEditModal.astro';

interface Props {
  title?: string;
  showCover?: boolean;
  bare?: boolean;
}
const { title = "Amma's Kitchen", showCover = false, bare = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#faf6ee" />
    <meta name="description" content="A digital book of family recipes — Amma's Kitchen." />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="paper-bg min-h-screen">
    {!bare && (
      <header class="book-header">
        <div class="mx-auto flex max-w-spread items-center gap-3 px-4 py-3 sm:px-6">
          <button type="button" class="header-btn" data-drawer-open aria-label="Open menu">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <path d="M3 6h14M3 10h14M3 14h14" stroke-linecap="round"/>
            </svg>
          </button>
          <a href="/" class="font-display text-xl tracking-wide text-[color:var(--ink)] hover:text-[color:var(--terracotta-deep)] transition" transition:persist>
            Amma's Kitchen
          </a>
          <div class="ml-auto hidden flex-1 max-w-sm md:block">
            <SearchBox compact />
          </div>
          <a href="/search/" class="header-btn md:hidden" aria-label="Search">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <circle cx="9" cy="9" r="6"/>
              <path d="m17 17-3.5-3.5" stroke-linecap="round"/>
            </svg>
          </a>
        </div>
      </header>
    )}

    <main class:list={['main-area', showCover && 'main-area--cover']}>
      <slot />
    </main>

    {!bare && <Drawer />}
    <RecipeEditModal />

    <style>
      .book-header {
        position: sticky;
        top: 0;
        z-index: 30;
        backdrop-filter: blur(8px);
        background: rgba(250, 246, 238, 0.82);
        border-bottom: 1px solid var(--paper-edge);
      }
      .header-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 999px;
        color: var(--ink-soft);
        background: transparent;
        border: 1px solid transparent;
        transition: all 140ms ease;
      }
      .header-btn:hover {
        color: var(--ink);
        background: var(--paper-deep);
      }
      .main-area {
        margin: 0 auto;
        padding: 2rem 1rem 6rem;
        max-width: 70rem;
      }
      .main-area--cover { padding: 0; max-width: none; }
      @media (min-width: 768px) {
        .main-area { padding: 3rem 2rem 7rem; }
      }
    </style>

    <script>
      // Press "/" to focus the search box.
      document.addEventListener('keydown', (e) => {
        if (e.key !== '/') return;
        const tag = (document.activeElement as HTMLElement | null)?.tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA') return;
        const input = document.querySelector(
          '[data-search-box] input[name="q"]'
        ) as HTMLInputElement | null;
        if (input) {
          e.preventDefault();
          input.focus();
        }
      });
    </script>

    <script is:inline>
      /**
       * Amma's Favorites — global heart toggle controller.
       *
       * One handler installs once per session and:
       *   1. Fetches `GET /api/favorites` on every page load (incl. Astro
       *      view-transitions) and reconciles each `[data-favorite-toggle]`
       *      heart and `[data-favorite-badge]` against the canonical set.
       *   2. Captures clicks on hearts before the parent <a> activates,
       *      optimistically flips the icon, and POSTs `/api/favorites/toggle`.
       *   3. Reverts the optimistic state if the network call fails.
       *   4. Updates the section-level favorite count banner and regenerates the
       *      Table of Contents "Amma's Favorites" grid from the live slug set.
       */
      (function () {
        if (window.__ammasFavoritesInit) return;
        window.__ammasFavoritesInit = true;

        var liveSet = null; // Set<string> of favourite slugs, or null until first fetch
        var inflight = null; // de-dupe fetches across rapid navigations
        var pending = new Set(); // slugs whose toggle request is in flight

        function applyHeartState(btn, isFav) {
          btn.setAttribute('data-favorite', isFav ? '1' : '0');
          btn.setAttribute('aria-pressed', isFav ? 'true' : 'false');
          var title = btn.getAttribute('data-title') || 'this recipe';
          btn.setAttribute(
            'aria-label',
            isFav
              ? 'Remove ' + title + " from Amma's Favorites"
              : 'Add ' + title + " to Amma's Favorites"
          );
        }

        function reconcileBadgesFor(slug, isFav) {
          var hearts = document.querySelectorAll('[data-favorite-toggle][data-slug="' + cssEscape(slug) + '"]');
          for (var i = 0; i < hearts.length; i++) {
            var heart = hearts[i];
            applyHeartState(heart, isFav);
            // The "Favorite" badge sits inside the same recipe card / detail
            // header. Toggle its visibility to match the heart so the chrome
            // doesn't lie when the live state diverges from the build seed.
            var scope = heart.closest('.recipe-card, .recipe-head, .result-card, .dup-row__main');
            if (scope) {
              var badges = scope.querySelectorAll('[data-favorite-badge]');
              for (var b = 0; b < badges.length; b++) {
                badges[b].hidden = !isFav;
              }
            }
          }
        }

        function reconcileAll() {
          if (!liveSet) return;
          var hearts = document.querySelectorAll('[data-favorite-toggle]');
          for (var i = 0; i < hearts.length; i++) {
            var heart = hearts[i];
            var slug = heart.getAttribute('data-slug') || '';
            if (pending.has(slug)) continue; // don't clobber an in-flight optimistic update
            var shouldBe = liveSet.has(slug);
            applyHeartState(heart, shouldBe);
          }
          // Reconcile any badges that aren't paired with a heart in scope
          // (e.g. search-result cards that render badges client-side without
          // an adjacent heart).
          var badges = document.querySelectorAll('[data-favorite-badge]');
          for (var j = 0; j < badges.length; j++) {
            var badge = badges[j];
            var scope2 = badge.closest('.recipe-card, .recipe-head, .result-card, .dup-row__main');
            if (!scope2) continue;
            var nearbyHeart = scope2.querySelector('[data-favorite-toggle]');
            if (!nearbyHeart) continue;
            var slug2 = nearbyHeart.getAttribute('data-slug') || '';
            badge.hidden = !liveSet.has(slug2);
          }
          updateDerivedFavoritesUI();
        }

        var contentsBriefsCache = null;
        var lastContentsPicksKey = '';

        function getContentsBriefs() {
          if (contentsBriefsCache) return contentsBriefsCache;
          var el = document.getElementById('contents-recipe-index');
          if (!el || !el.textContent) return null;
          try {
            contentsBriefsCache = JSON.parse(el.textContent);
          } catch (_) {
            contentsBriefsCache = null;
          }
          return contentsBriefsCache;
        }

        var CONTENTS_HEART_HTML =
          '<svg class="favorite-heart__icon favorite-heart__icon--outline" width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M10 16.5s-5.5-3.4-7-6.5C1.7 7.6 3.2 4.5 6 4.5c1.6 0 3 .9 4 2.3 1-1.4 2.4-2.3 4-2.3 2.8 0 4.3 3.1 3 5.5-1.5 3.1-7 6.5-7 6.5z" stroke-linejoin="round" stroke-linecap="round"/></svg>' +
          '<svg class="favorite-heart__icon favorite-heart__icon--filled" width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17s-6-3.7-7.5-7C1.2 7.4 3 4 6 4c1.6 0 3 .9 4 2.4C11 4.9 12.4 4 14 4c3 0 4.8 3.4 3.5 6-1.5 3.3-7.5 7-7.5 7z"/></svg>';

        function buildContentsRecipeCard(brief, isFav) {
          var art = document.createElement('article');
          art.className = 'recipe-card group';
          var heart = document.createElement('button');
          heart.type = 'button';
          heart.className = 'favorite-heart favorite-heart--card';
          heart.setAttribute('data-favorite-toggle', '');
          heart.setAttribute('data-slug', brief.slug);
          heart.setAttribute('data-title', brief.title);
          heart.setAttribute('data-favorite', isFav ? '1' : '0');
          heart.setAttribute('aria-pressed', isFav ? 'true' : 'false');
          heart.setAttribute(
            'aria-label',
            isFav
              ? 'Remove ' + brief.title + " from Amma's Favorites"
              : 'Add ' + brief.title + " to Amma's Favorites"
          );
          heart.innerHTML = CONTENTS_HEART_HTML;
          var link = document.createElement('a');
          link.href = brief.href;
          link.className = 'recipe-card__link';
          var row = document.createElement('div');
          row.className = 'flex items-baseline justify-between gap-3';
          var h3 = document.createElement('h3');
          h3.className = 'recipe-card__title';
          h3.textContent = brief.title;
          row.appendChild(h3);
          var secSpan = document.createElement('span');
          secSpan.className = 'recipe-card__section';
          secSpan.textContent = brief.section;
          row.appendChild(secSpan);
          link.appendChild(row);
          var metaRow = document.createElement('div');
          metaRow.className = 'mt-1 flex flex-wrap items-center gap-2';
          var badgeEl = document.createElement('span');
          badgeEl.className = 'badge badge-family';
          badgeEl.setAttribute('data-favorite-badge', '');
          badgeEl.hidden = !isFav;
          badgeEl.textContent = 'Favorite';
          metaRow.appendChild(badgeEl);
          if (brief.source) {
            var srcEl = document.createElement('span');
            srcEl.className = 'badge badge-source';
            srcEl.textContent = brief.source;
            metaRow.appendChild(srcEl);
          }
          if (typeof brief.ingredientsLen === 'number' && brief.ingredientsLen > 0) {
            var ing = document.createElement('span');
            ing.className = 'text-xs text-[color:var(--ink-faint)] font-sans';
            ing.textContent = brief.ingredientsLen + ' ingredients';
            metaRow.appendChild(ing);
          }
          link.appendChild(metaRow);
          if (brief.preview) {
            var p = document.createElement('p');
            p.className = 'mt-2 text-sm leading-snug text-[color:var(--ink-soft)] line-clamp-2';
            p.textContent = brief.preview + '\u2026';
            link.appendChild(p);
          }
          art.appendChild(heart);
          art.appendChild(link);
          return art;
        }

        function updateSectionFavoriteNote() {
          if (!liveSet) return;
          var note = document.querySelector('[data-section-family-note]');
          var msg = document.querySelector('[data-section-family-msg]');
          var sectionList = document.querySelector('.section-list');
          if (!note || !msg || !sectionList) return;
          var hearts = sectionList.querySelectorAll('[data-favorite-toggle]');
          var n = 0;
          for (var i = 0; i < hearts.length; i++) {
            var sl = hearts[i].getAttribute('data-slug');
            if (sl && liveSet.has(sl)) n++;
          }
          msg.textContent =
            n + ' ' + (n === 1 ? 'recipe is one of' : 'recipes are') + " Amma's Favorites.";
          note.hidden = n === 0;
        }

        function syncContentsFavoritesFromLiveSet() {
          if (!liveSet) return;
          var briefs = getContentsBriefs();
          var grid = document.querySelector('[data-contents-favorites-grid]');
          var root = document.querySelector('[data-contents-favorites-root]');
          if (!briefs || !grid || !root) return;
          var picks = [];
          for (var i = 0; i < briefs.length && picks.length < 6; i++) {
            var b = briefs[i];
            if (liveSet.has(b.slug)) picks.push(b);
          }
          var key = picks
            .map(function (p) {
              return p.slug;
            })
            .join('\0');
          if (key === lastContentsPicksKey && grid.childElementCount === picks.length) {
            root.hidden = picks.length === 0;
            return;
          }
          lastContentsPicksKey = key;
          while (grid.firstChild) grid.removeChild(grid.firstChild);
          for (var j = 0; j < picks.length; j++) {
            grid.appendChild(buildContentsRecipeCard(picks[j], true));
          }
          root.hidden = picks.length === 0;
        }

        function updateDerivedFavoritesUI() {
          if (!liveSet) return;
          updateSectionFavoriteNote();
          syncContentsFavoritesFromLiveSet();
        }

        async function refreshLiveState(force) {
          if (inflight && !force) return inflight;
          inflight = (async function () {
            try {
              var res = await fetch('/api/favorites', {
                headers: { accept: 'application/json' },
                cache: 'no-store',
              });
              if (!res.ok) return;
              var json = await res.json();
              if (json && Array.isArray(json.slugs)) {
                liveSet = new Set(json.slugs);
                reconcileAll();
              }
            } catch (_) {
              /* offline or static preview without the API; keep seed state */
            } finally {
              inflight = null;
            }
          })();
          return inflight;
        }

        async function postToggle(slug) {
          return await fetch('/api/favorites/toggle', {
            method: 'POST',
            headers: {
              'content-type': 'application/json',
            },
            body: JSON.stringify({ slug: slug }),
          });
        }

        async function handleToggleClick(btn) {
          var slug = btn.getAttribute('data-slug') || '';
          if (!slug) return;
          var current = btn.getAttribute('data-favorite') === '1';
          var optimistic = !current;

          // Optimistic UI flip.
          pending.add(slug);
          btn.setAttribute('data-pending', '1');
          applyHeartState(btn, optimistic);
          reconcileBadgesFor(slug, optimistic);

          try {
            var res = await postToggle(slug);
            if (!res.ok) {
              var msg = '';
              try { msg = (await res.json()).error || ''; } catch (_) { msg = await res.text(); }
              alert('Could not update favorite: ' + (msg || res.status));
              applyHeartState(btn, current);
              reconcileBadgesFor(slug, current);
              return;
            }
            var data = await res.json();
            var isFav = !!data.favorite;
            applyHeartState(btn, isFav);
            reconcileBadgesFor(slug, isFav);
            if (!liveSet) liveSet = new Set();
            if (isFav) liveSet.add(slug);
            else liveSet.delete(slug);
            updateDerivedFavoritesUI();
          } catch (err) {
            applyHeartState(btn, current);
            reconcileBadgesFor(slug, current);
            alert('Could not update favorite: ' + (err && err.message ? err.message : err));
          } finally {
            pending.delete(slug);
            btn.removeAttribute('data-pending');
          }
        }

        function onClickCapture(e) {
          var target = e.target;
          if (!target || !(target instanceof Element)) return;
          var btn = target.closest('[data-favorite-toggle]');
          if (!btn) return;
          // Hearts live inside <a> recipe-card links; preempt navigation.
          e.preventDefault();
          e.stopPropagation();
          if (typeof e.stopImmediatePropagation === 'function') {
            e.stopImmediatePropagation();
          }
          void handleToggleClick(btn);
        }

        // CSS.escape polyfill-ish: only escape characters that matter for
        // attribute selectors of slugs (which our slugify limits to
        // [a-z0-9-]). Defensive in case future slugs include odd chars.
        function cssEscape(s) {
          if (window.CSS && typeof window.CSS.escape === 'function') return window.CSS.escape(s);
          return String(s).replace(/[^a-zA-Z0-9_-]/g, '\\$&');
        }

        document.addEventListener('click', onClickCapture, true);
        document.addEventListener('astro:page-load', function () {
          contentsBriefsCache = null;
          lastContentsPicksKey = '';
          reconcileAll();
          void refreshLiveState(true);
        });

        // Re-reconcile when new hearts/badges enter the DOM — search results
        // render their cards client-side after the page loads, so an
        // up-front reconcile would miss them.
        var moTimer = 0;
        try {
          var mo = new MutationObserver(function (records) {
            for (var i = 0; i < records.length; i++) {
              var added = records[i].addedNodes;
              for (var j = 0; j < added.length; j++) {
                var n = added[j];
                if (!(n instanceof Element)) continue;
                if (n.matches && (n.matches('[data-favorite-toggle], [data-favorite-badge]')
                  || n.querySelector && n.querySelector('[data-favorite-toggle], [data-favorite-badge]'))) {
                  if (moTimer) cancelAnimationFrame(moTimer);
                  moTimer = requestAnimationFrame(function () {
                    moTimer = 0;
                    reconcileAll();
                  });
                  return;
                }
              }
            }
          });
          mo.observe(document.body, { childList: true, subtree: true });
        } catch (_) { /* MO unsupported — accept stale badges */ }

        // First load (before the persisted listener above is wired by Astro).
        reconcileAll();
        void refreshLiveState(true);
      })();
    </script>
  </body>
</html>
