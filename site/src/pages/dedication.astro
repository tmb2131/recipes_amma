---
import BookLayout from '../layouts/BookLayout.astro';
import Floral from '../components/Floral.astro';
export const prerender = true;
---
<BookLayout title="Dedication — Amma's Kitchen" bare>
  <section class="dedication" data-pagefind-ignore>
    <Floral variant="marigold" class="dedication-motif" width={56} height={56} />

    <p class="dedication-eyebrow">Dedication</p>

    <div class="dedication-body">
      <p>For Sriya —</p>
      <p>a piece of Amma to always remember.</p>
    </div>

    <Floral variant="divider" class="dedication-divider" width={240} />

    <div class="dedication-actions">
      <a href="/contents/" class="dedication-cta">
        <span>Continue</span>
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M8 4l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>
</BookLayout>

<style>
  .dedication {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    max-width: 32rem;
    margin: 0 auto;
  }
  .dedication-motif {
    color: var(--gold);
    margin: 0 auto 1.5rem;
    display: block;
    opacity: 0.85;
  }
  .dedication-eyebrow {
    font-family: var(--sans);
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0 0 2.5rem;
  }
  .dedication-body {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.4rem, 3.6vw, 1.85rem);
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }
  .dedication-body p {
    margin: 0;
  }
  .dedication-body p + p {
    margin-top: 0.6rem;
  }
  .dedication-divider {
    color: var(--gold-soft);
    margin: 2.5rem auto 0;
    display: block;
    opacity: 0.85;
  }
  .dedication-actions {
    margin-top: 4rem;
  }
  .dedication-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.4rem;
    border: 1px solid var(--paper-edge);
    border-radius: 999px;
    color: var(--ink-soft);
    background: transparent;
    font-family: var(--sans);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: all 240ms ease;
  }
  .dedication-cta:hover {
    color: var(--ink);
    border-color: var(--gold-soft);
    background: rgba(232, 176, 74, 0.08);
    transform: translateY(-1px);
  }
  .dedication-cta svg { transition: transform 240ms ease; }
  .dedication-cta:hover svg { transform: translateX(3px); }
</style>
