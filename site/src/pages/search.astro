---
import BookLayout from '../layouts/BookLayout.astro';
import SearchBox from '../components/SearchBox.astro';
import Floral from '../components/Floral.astro';

export const prerender = true;
---
<BookLayout title="Search — Amma's Kitchen">
  <section class="search-head">
    <Floral variant="sprig" class="search-motif" width={56} height={56} />
    <h1 class="search-title">Search the book</h1>
    <p class="search-sub">Find a dish by name, ingredient, or technique.</p>
    <div class="search-input-wrap">
      <SearchBox autofocus />
    </div>
  </section>

  <section id="search-results" class="search-results" aria-live="polite" data-pagefind-ignore>
    <p class="search-hint">Try <em>aubergine</em>, <em>sambar</em>, or <em>"black beans"</em> for an exact phrase.</p>
  </section>
</BookLayout>

<style>
  .search-head { text-align: center; margin: 0 auto 2.5rem; max-width: 32rem; }
  .search-motif { color: var(--sage); margin: 0 auto 0.4rem; display: block; }
  .search-title { font-family: var(--display); font-size: clamp(2.2rem, 5vw, 3.4rem); margin: 0; }
  .search-sub { font-family: var(--script); font-size: 1.3rem; color: var(--sage-deep); margin: 0.4rem 0 0; }
  .search-input-wrap { margin: 1.6rem auto 0; }
  .search-results { max-width: 50rem; margin: 0 auto; }
  .search-hint { text-align: center; color: var(--ink-faint); font-style: italic; }
  .search-hint em { color: var(--terracotta); font-style: italic; }

  :global(.result-group) { margin-bottom: 2rem; }
  :global(.result-group__title) {
    font-family: var(--display);
    font-size: 1.2rem;
    color: var(--terracotta-deep);
    margin: 0 0 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--paper-edge);
    display: flex; align-items: baseline; justify-content: space-between;
  }
  :global(.result-group__count) {
    font-family: var(--sans); font-size: 0.7rem; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ink-faint);
  }
  :global(.result-card) {
    position: relative;
    display: block;
    padding: 0.85rem 1rem;
    border-radius: 10px;
    border: 1px solid transparent;
    transition: all 160ms ease;
  }
  :global(.result-card:hover) {
    background: rgba(195, 157, 78, 0.08);
    border-color: var(--paper-edge);
    transform: translateY(-1px);
  }
  :global(.result-card__head) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }
  :global(.result-card__title) {
    font-family: var(--display); font-size: 1.15rem; color: var(--ink); line-height: 1.25;
  }
  :global(.result-card:hover .result-card__title) { color: var(--terracotta-deep); }
  :global(.result-card__section) {
    font-family: var(--sans);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  :global(.result-card__meta) {
    margin-top: 0.35rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
  }
  :global(.result-card__ingredients) {
    font-size: 0.75rem;
    color: var(--ink-faint);
    font-family: var(--sans);
  }
  :global(.result-card__excerpt) {
    margin: 0.5rem 0 0; font-size: 0.92rem; color: var(--ink-soft); line-height: 1.4;
  }
  :global(.result-card__excerpt mark),
  :global(.result-card__title mark) {
    background: rgba(232, 176, 74, 0.4); color: inherit; padding: 0 0.1em; border-radius: 2px;
  }
  :global(.result-card__title mark) { font-weight: inherit; }
  .empty {
    text-align: center; color: var(--ink-faint); font-style: italic; margin: 2rem 0;
  }
</style>

<script>
  const SECTIONS = ['Indian', 'Asian', 'Fish', 'Soup', 'Salad', 'Dressing', 'Desserts', 'Sylvestre', 'Other'];

  type IndexedRecipe = {
    href: string;
    title: string;
    section: string;
    source: string;
    family: boolean;
    ingredients: string[];
    excerpt: string;
    preview: string;
  };

  type SearchHit = {
    recipe: IndexedRecipe;
    score: number;
    matchedExcerpt: string;
  };

  type ParsedQuery = {
    requiredPhrases: string[];
    tokens: string[];
    phraseCandidate: string;
  };

  // ---------- Index load (lazy, cached) ----------

  let indexPromise: Promise<IndexedRecipe[]> | null = null;
  type IndexCacheEntry = IndexedRecipe & {
    _titleLower: string;
    _ingredientsLower: string[];
    _excerptLower: string;
    _haystack: string;
  };
  let indexCache: IndexCacheEntry[] | null = null;

  function loadIndex(): Promise<IndexedRecipe[]> {
    if (!indexPromise) {
      indexPromise = fetch('/search-index.json', { cache: 'force-cache' })
        .then((r) => {
          if (!r.ok) throw new Error(`search-index ${r.status}`);
          return r.json() as Promise<IndexedRecipe[]>;
        })
        .then((data) => {
          indexCache = data.map((r) => {
            const ingredientsLower = r.ingredients.map((i) => i.toLowerCase());
            const titleLower = r.title.toLowerCase();
            const excerptLower = r.excerpt.toLowerCase();
            return {
              ...r,
              _titleLower: titleLower,
              _ingredientsLower: ingredientsLower,
              _excerptLower: excerptLower,
              _haystack: `${titleLower} ${ingredientsLower.join(' ')} ${excerptLower}`,
            };
          });
          return data;
        });
    }
    return indexPromise;
  }

  // ---------- Query parser ----------

  function parseQuery(raw: string): ParsedQuery {
    const phrases: string[] = [];
    let stripped = '';
    const re = /"([^"]+)"/g;
    let last = 0;
    let m: RegExpExecArray | null;
    while ((m = re.exec(raw)) !== null) {
      stripped += raw.slice(last, m.index) + ' ';
      const phrase = m[1].trim().toLowerCase();
      if (phrase.length >= 2) phrases.push(phrase);
      last = m.index + m[0].length;
    }
    stripped += raw.slice(last);
    stripped = stripped.replace(/\s+/g, ' ').trim().toLowerCase();
    const tokens = Array.from(
      new Set(stripped.split(/\s+/).filter((t) => t.length >= 2)),
    );
    // Only use the unquoted text as a "phrase candidate" if there were no quoted
    // phrases — otherwise the user has already told us which phrase matters.
    const phraseCandidate =
      phrases.length === 0 && tokens.length >= 2 ? stripped : '';
    return { requiredPhrases: phrases, tokens, phraseCandidate };
  }

  // ---------- Scoring ----------

  const PHRASE_INGREDIENT_CAP = 3;

  function scoreRecipe(rec: IndexCacheEntry, q: ParsedQuery): number {
    // Gates: every required phrase and every token must appear somewhere.
    for (const p of q.requiredPhrases) {
      if (!rec._haystack.includes(p)) return -1;
    }
    for (const t of q.tokens) {
      if (!rec._haystack.includes(t)) return -1;
    }

    let score = 0;

    if (q.phraseCandidate.length >= 2) {
      const phrase = q.phraseCandidate;
      if (rec._titleLower.includes(phrase)) score += 50;
      if (rec._titleLower.startsWith(phrase)) score += 30;
      let ingHits = 0;
      for (const ing of rec._ingredientsLower) {
        if (ing.includes(phrase)) ingHits++;
      }
      score += Math.min(ingHits, PHRASE_INGREDIENT_CAP) * 20;
      if (rec._excerptLower.includes(phrase)) score += 5;
    }

    for (const phrase of q.requiredPhrases) {
      if (rec._titleLower.includes(phrase)) score += 40;
      let ingHits = 0;
      for (const ing of rec._ingredientsLower) {
        if (ing.includes(phrase)) ingHits++;
      }
      score += Math.min(ingHits, PHRASE_INGREDIENT_CAP) * 15;
      if (rec._excerptLower.includes(phrase)) score += 3;
    }

    for (const t of q.tokens) {
      if (rec._titleLower.includes(t)) score += 8;
      const inIngredient = rec._ingredientsLower.some((ing) => ing.includes(t));
      if (inIngredient) score += 4;
      if (rec._excerptLower.includes(t)) score += 1;
    }

    return score;
  }

  function searchRecipes(q: ParsedQuery): SearchHit[] {
    if (!indexCache) return [];
    if (
      q.requiredPhrases.length === 0 &&
      q.tokens.length === 0 &&
      q.phraseCandidate.length === 0
    ) {
      return [];
    }
    const hits: SearchHit[] = [];
    for (const rec of indexCache) {
      const score = scoreRecipe(rec, q);
      if (score <= 0) continue;
      const matchedExcerpt = buildExcerpt(rec, q);
      hits.push({ recipe: rec, score, matchedExcerpt });
    }
    hits.sort(
      (a, b) => b.score - a.score || a.recipe.title.localeCompare(b.recipe.title),
    );
    return hits.slice(0, 60);
  }

  // ---------- Excerpt + highlight ----------

  function buildExcerpt(rec: IndexCacheEntry, q: ParsedQuery): string {
    // Prefer a matched ingredient line — it's the most informative snippet
    // for an ingredient search.
    const targets = [
      ...q.requiredPhrases,
      ...(q.phraseCandidate ? [q.phraseCandidate] : []),
      ...q.tokens,
    ];
    for (const t of targets) {
      const idx = rec._ingredientsLower.findIndex((ing) => ing.includes(t));
      if (idx >= 0) return rec.ingredients[idx];
    }
    // Otherwise show a body window around the first match.
    for (const t of targets) {
      const at = rec._excerptLower.indexOf(t);
      if (at >= 0) {
        const start = Math.max(0, at - 30);
        const end = Math.min(rec.excerpt.length, at + 100);
        const prefix = start > 0 ? '…' : '';
        const suffix = end < rec.excerpt.length ? '…' : '';
        return prefix + rec.excerpt.slice(start, end) + suffix;
      }
    }
    return rec.preview;
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c] as string));
  }

  function escapeRegex(s: string) {
    return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function highlight(text: string, q: ParsedQuery): string {
    if (!text) return '';
    const terms = [
      ...q.requiredPhrases,
      ...(q.phraseCandidate ? [q.phraseCandidate] : []),
      ...q.tokens,
    ]
      .filter(Boolean)
      // Longer terms first so phrase highlights aren't shadowed by token highlights.
      .sort((a, b) => b.length - a.length);
    if (terms.length === 0) return escapeHtml(text);
    const pattern = new RegExp(`(${terms.map(escapeRegex).join('|')})`, 'gi');
    // Split on the pattern so capture groups are interleaved with non-match
    // segments — escape non-matches, wrap matches in <mark>.
    const parts = text.split(pattern);
    return parts
      .map((part, i) =>
        i % 2 === 1 ? `<mark>${escapeHtml(part)}</mark>` : escapeHtml(part),
      )
      .join('');
  }

  // ---------- Rendering ----------

  const resultsEl = document.getElementById('search-results') as HTMLElement;
  const input = document.querySelector(
    '[data-search-box] input[name="q"]',
  ) as HTMLInputElement | null;

  function renderCard(hit: SearchHit, q: ParsedQuery) {
    const r = hit.recipe;
    const title = highlight(r.title, q);
    const section = escapeHtml(r.section);
    const source = r.source
      ? `<span class="badge badge-source">${escapeHtml(r.source)}</span>`
      : '';
    const ingredients = r.ingredients.length
      ? `<span class="result-card__ingredients">${r.ingredients.length} ingredients</span>`
      : '';
    const excerpt = hit.matchedExcerpt
      ? `<p class="result-card__excerpt">${highlight(hit.matchedExcerpt, q)}</p>`
      : '';
    return `
      <a class="result-card" href="${r.href}/">
        <div class="result-card__head">
          <div class="result-card__title">${title}</div>
          <span class="result-card__section">${section}</span>
        </div>
        <div class="result-card__meta">
          ${source}
          ${ingredients}
        </div>
        ${excerpt}
      </a>
    `;
  }

  function renderResults(hits: SearchHit[], q: ParsedQuery, rawQuery: string) {
    if (hits.length === 0) {
      resultsEl.innerHTML = `<p class="empty">No recipes match "${escapeHtml(rawQuery)}". Try a simpler word.</p>`;
      return;
    }
    const groups = new Map<string, SearchHit[]>();
    for (const h of hits) {
      const list = groups.get(h.recipe.section) ?? [];
      list.push(h);
      groups.set(h.recipe.section, list);
    }
    const ordered = SECTIONS
      .map((s) => [s, groups.get(s) ?? []] as const)
      .filter(([, items]) => items.length > 0);

    const html = ordered
      .map(
        ([section, items]) => `
      <section class="result-group">
        <h2 class="result-group__title">
          <span>${section}</span>
          <span class="result-group__count">${items.length} ${items.length === 1 ? 'match' : 'matches'}</span>
        </h2>
        ${items.map((h) => renderCard(h, q)).join('')}
      </section>
    `,
      )
      .join('');
    resultsEl.innerHTML = html;
  }

  // ---------- Run + debounce ----------

  let lastQuery = '';
  let debounceId: number | null = null;

  async function runSearch(rawQuery: string) {
    const trimmed = rawQuery.trim();
    if (trimmed.length < 2) {
      resultsEl.innerHTML = '<p class="search-hint">Type at least two letters.</p>';
      lastQuery = '';
      return;
    }
    if (trimmed === lastQuery) return;
    lastQuery = trimmed;
    resultsEl.setAttribute('aria-busy', 'true');

    try {
      await loadIndex();
    } catch (err) {
      resultsEl.innerHTML = '<p class="empty">Search index failed to load. Please refresh.</p>';
      resultsEl.setAttribute('aria-busy', 'false');
      if (import.meta.env.DEV) console.warn('search-index load failed', err);
      return;
    }

    const parsed = parseQuery(rawQuery);
    const hits = searchRecipes(parsed);
    renderResults(hits, parsed, rawQuery);
    resultsEl.setAttribute('aria-busy', 'false');
  }

  function onInput(e: Event) {
    const q = (e.target as HTMLInputElement).value;
    if (debounceId) window.clearTimeout(debounceId);
    debounceId = window.setTimeout(() => runSearch(q), 140) as unknown as number;
  }

  if (input) {
    input.addEventListener('input', onInput);
    const url = new URL(window.location.href);
    const initial = url.searchParams.get('q') ?? '';
    if (initial) {
      input.value = initial;
      runSearch(initial);
    }
    input.form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const u = new URL(window.location.href);
      u.searchParams.set('q', input.value);
      window.history.replaceState(null, '', u);
    });
  }
</script>
