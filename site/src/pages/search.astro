---
import BookLayout from '../layouts/BookLayout.astro';
import SearchBox from '../components/SearchBox.astro';
import Floral from '../components/Floral.astro';
import { getRecipes } from '../lib/loadRecipes';

export const prerender = true;

const normalizeHref = (url: string) => {
  const clean = url.startsWith('/') ? url : `/${url}`;
  return clean.endsWith('/') ? clean.slice(0, -1) : clean;
};

const isDev = import.meta.env.DEV;

const recipeLookup = Object.fromEntries(
  getRecipes().map((recipe) => {
    const cleanedBody = recipe.body
      .replace(/[#*`>_\[\]\\]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();
    const preview = cleanedBody.slice(0, 130);
    const ingredientsText = (recipe.ingredients ?? []).join(' ');
    const text = isDev
      ? `${recipe.title} ${ingredientsText} ${cleanedBody.slice(0, 600)}`
          .toLowerCase()
      : undefined;

    return [
      normalizeHref(recipe.href),
      {
        title: recipe.title,
        section: recipe.section,
        source: recipe.source ?? '',
        family: recipe.family,
        ingredientsCount: recipe.ingredients?.length ?? 0,
        preview,
        ...(text ? { text } : {}),
      },
    ];
  })
);
---
<BookLayout title="Search — Amma's Kitchen">
  <section class="search-head">
    <Floral variant="sprig" class="search-motif" width={56} height={56} />
    <h1 class="search-title">Search the book</h1>
    <p class="search-sub">Find a dish by name, ingredient, or technique.</p>
    <div class="search-input-wrap">
      <SearchBox autofocus />
    </div>
  </section>

  <section id="search-results" class="search-results" aria-live="polite" data-pagefind-ignore>
    <p class="search-hint">Try <em>aubergine</em>, <em>amma</em>, <em>sambar</em>, or <em>chocolate</em>.</p>
  </section>

  <script type="application/json" id="recipe-lookup-data" set:html={JSON.stringify(recipeLookup)} />
</BookLayout>

<style>
  .search-head { text-align: center; margin: 0 auto 2.5rem; max-width: 32rem; }
  .search-motif { color: var(--sage); margin: 0 auto 0.4rem; display: block; }
  .search-title { font-family: var(--display); font-size: clamp(2.2rem, 5vw, 3.4rem); margin: 0; }
  .search-sub { font-family: var(--script); font-size: 1.3rem; color: var(--sage-deep); margin: 0.4rem 0 0; }
  .search-input-wrap { margin: 1.6rem auto 0; }
  .search-results { max-width: 50rem; margin: 0 auto; }
  .search-hint { text-align: center; color: var(--ink-faint); font-style: italic; }
  .search-hint em { color: var(--terracotta); font-style: italic; }

  :global(.result-group) { margin-bottom: 2rem; }
  :global(.result-group__title) {
    font-family: var(--display);
    font-size: 1.2rem;
    color: var(--terracotta-deep);
    margin: 0 0 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--paper-edge);
    display: flex; align-items: baseline; justify-content: space-between;
  }
  :global(.result-group__count) {
    font-family: var(--sans); font-size: 0.7rem; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ink-faint);
  }
  :global(.result-card) {
    position: relative;
    display: block;
    padding: 0.85rem 1rem;
    border-radius: 10px;
    border: 1px solid transparent;
    transition: all 160ms ease;
  }
  :global(.result-card:hover) {
    background: rgba(195, 157, 78, 0.08);
    border-color: var(--paper-edge);
    transform: translateY(-1px);
  }
  :global(.result-card__head) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }
  :global(.result-card__title) {
    font-family: var(--display); font-size: 1.15rem; color: var(--ink); line-height: 1.25;
  }
  :global(.result-card:hover .result-card__title) { color: var(--terracotta-deep); }
  :global(.result-card__section) {
    font-family: var(--sans);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  :global(.result-card__meta) {
    margin-top: 0.35rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
  }
  :global(.result-card__ingredients) {
    font-size: 0.75rem;
    color: var(--ink-faint);
    font-family: var(--sans);
  }
  :global(.result-card__excerpt) {
    margin: 0.5rem 0 0; font-size: 0.92rem; color: var(--ink-soft); line-height: 1.4;
  }
  :global(.result-card__excerpt mark) {
    background: rgba(232, 176, 74, 0.4); color: inherit; padding: 0 0.1em; border-radius: 2px;
  }
  .empty {
    text-align: center; color: var(--ink-faint); font-style: italic; margin: 2rem 0;
  }
</style>

<script>
  const SECTIONS = ['Indian', 'Asian', 'Fish', 'Soup', 'Salad', 'Dressing', 'Desserts', 'Sylvestre', 'Other'];

  type SearchResult = {
    url: string;
    sub_results?: { url: string; title: string; excerpt: string }[];
    excerpt: string;
    meta?: { title?: string };
  };
  type RecipeLookupItem = {
    title: string;
    section: string;
    source: string;
    family: boolean;
    ingredientsCount: number;
    preview: string;
    text?: string;
  };

  const lookupEl = document.getElementById('recipe-lookup-data');
  let recipeLookup: Record<string, RecipeLookupItem> = {};
  try {
    recipeLookup = lookupEl?.textContent ? JSON.parse(lookupEl.textContent) : {};
  } catch (err) {
    console.warn('Failed to parse recipe lookup', err);
  }

  let pagefindPromise: Promise<any> | null = null;
  function loadPagefind() {
    if (!pagefindPromise) {
      // Build the URL at runtime so Rollup doesn't try to resolve it.
      const url = new URL('/pagefind/pagefind.js', window.location.href).href;
      pagefindPromise = (async () => {
        const pf = await import(/* @vite-ignore */ /* webpackIgnore: true */ url);
        await pf.options({ excerptLength: 24 });
        return pf;
      })().catch((err) => {
        console.warn('Pagefind not available yet', err);
        pagefindPromise = null;
        throw err;
      });
    }
    return pagefindPromise;
  }

  const resultsEl = document.getElementById('search-results') as HTMLElement;
  const input = document.querySelector(
    '[data-search-box] input[name="q"]'
  ) as HTMLInputElement | null;

  function getSection(url: string): string {
    const m = url.match(/^\/?([^/]+)\//);
    if (!m) return 'Other';
    const slug = m[1].toLowerCase();
    const found = SECTIONS.find((s) => s.toLowerCase() === slug);
    return found ?? 'Other';
  }

  let lastQuery = '';
  let debounceId: number | null = null;

  async function runSearch(q: string) {
    if (q.trim().length < 2) {
      resultsEl.innerHTML = '<p class="search-hint">Type at least two letters.</p>';
      return;
    }
    if (q === lastQuery) return;
    lastQuery = q;

    resultsEl.setAttribute('aria-busy', 'true');

    let data: SearchResult[] | null = null;
    try {
      const pf = await loadPagefind();
      const search = await pf.search(q);
      if (search && search.results && search.results.length > 0) {
        const slice = search.results.slice(0, 60);
        data = await Promise.all(slice.map((r: any) => r.data()));
      } else {
        data = [];
      }
    } catch {
      data = localSearch(q);
    }

    if (!data || data.length === 0) {
      resultsEl.setAttribute('aria-busy', 'false');
      resultsEl.innerHTML = `<p class="empty">No recipes match "${escapeHtml(q)}". Try a simpler word.</p>`;
      return;
    }

    const groups = new Map<string, SearchResult[]>();
    for (const d of data) {
      const section = getSection(d.url);
      if (!groups.has(section)) groups.set(section, []);
      groups.get(section)!.push(d);
    }

    const ordered = SECTIONS
      .map((s) => [s, groups.get(s) ?? []] as const)
      .filter(([, items]) => items.length > 0);

    const html = ordered.map(([section, items]) => `
      <section class="result-group">
        <h2 class="result-group__title">
          <span>${section}</span>
          <span class="result-group__count">${items.length} ${items.length === 1 ? 'match' : 'matches'}</span>
        </h2>
        ${items.map((r) => `
          <a class="result-card" href="${r.url}">
            ${renderCard(r)}
          </a>
        `).join('')}
      </section>
    `).join('');

    resultsEl.innerHTML = html;
    resultsEl.setAttribute('aria-busy', 'false');
  }

  function localSearch(q: string): SearchResult[] {
    const needle = q.trim().toLowerCase();
    if (!needle) return [];
    const tokens = needle.split(/\s+/).filter(Boolean);
    const matches: { result: SearchResult; score: number }[] = [];

    for (const [href, recipe] of Object.entries(recipeLookup)) {
      const haystack = (recipe.text ?? `${recipe.title} ${recipe.preview}`).toLowerCase();
      const titleLower = recipe.title.toLowerCase();
      let score = 0;
      let allMatch = true;
      for (const t of tokens) {
        if (titleLower.includes(t)) score += 5;
        else if (haystack.includes(t)) score += 1;
        else { allMatch = false; break; }
      }
      if (!allMatch) continue;
      if (titleLower.startsWith(needle)) score += 10;
      matches.push({
        result: {
          url: `${href}/`,
          excerpt: recipe.preview,
          meta: { title: recipe.title },
        },
        score,
      });
    }

    matches.sort((a, b) =>
      b.score - a.score ||
      a.result.meta!.title!.localeCompare(b.result.meta!.title!)
    );
    return matches.slice(0, 60).map((m) => m.result);
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }

  function renderCard(result: SearchResult) {
    const key = normalizeHref(result.url);
    const recipe = recipeLookup[key];
    const title = escapeHtml(recipe?.title ?? result.meta?.title ?? result.url);
    const section = escapeHtml(recipe?.section ?? getSection(result.url));
    const source = recipe?.source ? `<span class="badge badge-source">${escapeHtml(recipe.source)}</span>` : '';
    const family = recipe?.family ? '<span class="badge badge-family" data-favorite-badge>Favorite</span>' : '';
    const ingredients = recipe?.ingredientsCount
      ? `<span class="result-card__ingredients">${recipe.ingredientsCount} ingredients</span>`
      : '';
    const excerpt = result.excerpt || recipe?.preview
      ? `<p class="result-card__excerpt">${result.excerpt || escapeHtml(recipe?.preview ?? '')}</p>`
      : '';

    return `
      <div class="result-card__head">
        <div class="result-card__title">${title}</div>
        <span class="result-card__section">${section}</span>
      </div>
      <div class="result-card__meta">
        ${family}
        ${source}
        ${ingredients}
      </div>
      ${excerpt}
    `;
  }

  function normalizeHref(url: string) {
    const clean = url.startsWith('/') ? url : `/${url}`;
    return clean.endsWith('/') ? clean.slice(0, -1) : clean;
  }

  function onInput(e: Event) {
    const q = (e.target as HTMLInputElement).value;
    if (debounceId) window.clearTimeout(debounceId);
    debounceId = window.setTimeout(() => runSearch(q), 140) as unknown as number;
  }

  if (input) {
    input.addEventListener('input', onInput);
    const url = new URL(window.location.href);
    const initial = url.searchParams.get('q') ?? '';
    if (initial) {
      input.value = initial;
      runSearch(initial);
    }
    // Submitting the form just keeps query in URL.
    input.form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const u = new URL(window.location.href);
      u.searchParams.set('q', input.value);
      window.history.replaceState(null, '', u);
    });
  }
</script>
